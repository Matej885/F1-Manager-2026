<Window x:Class="F1_Manager_2026.Menu.MainCareerMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:F1_Manager_2026.Menu"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Title="MainCareerMenu" Height="1080" Width="1920"
        Icon="/Images/Program_icon.png">
    <Grid Background="#0F0F0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="956*"/>
            <RowDefinition Height="36*"/>
            <RowDefinition Height="89*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="3" VerticalAlignment="Top" Height="80" Background="#1A1A1A" BorderBrush="#E10600" BorderThickness="0,0,0,3" Panel.ZIndex="10">
            <Grid Margin="40,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Name="Team_Logo_Small" Width="50" Height="50" Margin="0,0,20,0"/>
                    <Label Name="Team_Name_Top" Content="SCUDERIA FERRARI" Foreground="White" FontSize="28" FontFamily="Bahnschrift" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Label Content="BUDGET:" Foreground="Gray" FontSize="18" VerticalAlignment="Center"/>
                    <Label Name="Budget_Label" Content="" Foreground="LightGreen" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,40,0"/>
                    <Label Content="SEASON 2026" Foreground="White" FontSize="18" VerticalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Column="0" Margin="30,120,10,0" Grid.RowSpan="3">
            <Border Background="#1A1A1A" CornerRadius="10" Padding="20" BorderBrush="#333" BorderThickness="1">
                <StackPanel>
                    <Label Content="TEAM PRINCIPAL" Foreground="#E10600" FontSize="14" FontWeight="Bold"/>
                    <Label Name="Principal_Name" Content="MATEJ TICHÝ" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <Separator Background="#333" Margin="0,10"/>
                    <Button Content="NEXT RACE: " Background="#E10600" Foreground="White" Height="50" FontWeight="Bold" Margin="0,10,0,0" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="0,30,0,0">
                <Button Content="CAR DEVELOPMENT" Height="55" Margin="0,5" Background="#222" Foreground="White" BorderBrush="#444" HorizontalContentAlignment="Left" Padding="20,0" Cursor="Hand" Click="Button_Click_Upgrade"/>
                <Button Content="FACILITIES" Height="55" Margin="0,5" Background="#222" Foreground="White" BorderBrush="#444" HorizontalContentAlignment="Left" Padding="20,0" Cursor="Hand"/>
                <Button Content="STAFF &amp; SCOUTING" Height="55" Margin="0,5" Background="#222" Foreground="White" BorderBrush="#444" HorizontalContentAlignment="Left" Padding="20,0" Cursor="Hand"/>
                <Button Content="SPONSORS" Height="55" Margin="0,5" Background="#222" Foreground="White" BorderBrush="#444" HorizontalContentAlignment="Left" Padding="20,0" Cursor="Hand"/>
                <Button Content="STANDINGS" Height="55" Margin="0,5" Background="#222" Foreground="White" BorderBrush="#444" HorizontalContentAlignment="Left" Padding="20,0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1" Margin="20,120,20,20" Grid.RowSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="784*"/>
                <RowDefinition Height="29*"/>
                <RowDefinition Height="127*"/>
            </Grid.RowDefinitions>
            <StackPanel VerticalAlignment="Top">
                <Label Name="Car_Model_Name" Content="" HorizontalAlignment="Center" Foreground="White" FontSize="42" FontWeight="Bold" Margin="0,-10,0,0"/>
            </StackPanel>

            <Image Name="Main_Car_Preview"  Stretch="Uniform" VerticalAlignment="Top" Margin="0,420,0,0"/>

            <UniformGrid Columns="3" VerticalAlignment="Top" Height="120" Margin="0,780,0,0" Grid.RowSpan="3">
                <Border Background="#151515" Margin="5" CornerRadius="5" BorderBrush="#333" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Label Content="TOP SPEED" Foreground="Gray" HorizontalAlignment="Center"/>
                        <Label Content="342 KM/H" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background ="#0F0F0F" Margin="5" CornerRadius="5" BorderBrush="#333" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Label Content="" Foreground="Gray" HorizontalAlignment="Center"/>
                        <Label Content="" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#151515" Margin="5" CornerRadius="5" BorderBrush="#333" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Label Content="RELIABILITY" Foreground="Gray" HorizontalAlignment="Center"/>
                        <Label Content="88%" Foreground="#FFD700" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>

        <StackPanel Grid.Column="2" Margin="10,120,40,0" Grid.RowSpan="3">
            <Label Content="DRIVER LINEUP" Foreground="#E10600" FontSize="20" FontFamily="Bahnschrift" FontWeight="Bold" Margin="0,0,0,20"/>

            <Border Background="#1A1A1A" BorderBrush="#444" BorderThickness="1" CornerRadius="10" Margin="0,0,0,20" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Name="Driver1_Face"  Height="80" Width="80" Stretch="UniformToFill"/>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <Label Name="NameLabel1" Content="CHARLES LECLERC" Foreground="White" FontSize="18" FontWeight="Bold" Padding="0"/>
                        <Label Name="RatingLabel1" Content="RATING: 92" Foreground="LightGreen" FontSize="14" Padding="0"/>
                        <ProgressBar Value="92" Height="5" Margin="0,10,0,0" Foreground="#E10600" Background="#333" BorderThickness="0"/>
                        <Label Content="STATUS: Number 1" Foreground="Gray" FontSize="11" Padding="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#1A1A1A" BorderBrush="#444" BorderThickness="1" CornerRadius="10" Margin="0,0,0,20" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Name="Driver2_Face"  Height="80" Width="80" Stretch="UniformToFill"/>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <Label Name="NameLabel2" Content="LEWIS HAMILTON" Foreground="White" FontSize="18" FontWeight="Bold" Padding="0"/>
                        <Label Name="RatingLabel2" Content="RATING: 90" Foreground="LightGreen" FontSize="14" Padding="0"/>
                        <ProgressBar Value="90" Height="5" Margin="0,10,0,0" Foreground="#E10600" Background="#333" BorderThickness="0"/>
                        <Label Content="STATUS: Number 2" Foreground="Gray" FontSize="11" Padding="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Label Content="LATEST NEWS" Foreground="White" FontSize="18" Margin="0,20,0,10"/>
            <Border Background="#050505" BorderBrush="#333" BorderThickness="1" Height="200" CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <TextBlock Padding="10" Foreground="#AAA" FontSize="13" TextWrapping="Wrap" FontFamily="Consolas">
                        > New regulation changes proposed for 2027.<LineBreak/>
                        > Upgrade to Wind Tunnel finished.<LineBreak/>
                        > Sponsor "Shell" is happy with recent results.<LineBreak/>
                        > Driver market heating up for next season...
                    </TextBlock>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <Button Content="EXIT TO MENU" Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                Margin="0,0,40,40" Width="200" Height="50" Background="Transparent" Foreground="Gray" 
                BorderBrush="#333" BorderThickness="1" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="Button_Click" Grid.RowSpan="2" Grid.Row="1"/>
        <Button  Background="DarkRed"  FontSize="10" Content="Close game" HorizontalAlignment="Left" Margin="10,0,0,10" VerticalAlignment="Bottom" Height="23" Width="76" Click="Button_Click_1" Grid.Row="2"/>
        <Button  Background="DarkOliveGreen"  FontSize="10" Content="Save game" HorizontalAlignment="Left" Margin="10,0,0,65" VerticalAlignment="Bottom" Height="23" Width="76" Click="Button_Click_Save" Grid.Row="2"/>
    </Grid>
</Window>
