<Window x:Class="F1_Manager_2026.Menu.MainCareerMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Title="F1 Manager 2026" 
        Height="1080" Width="1920"
        Background="#050505"
        Icon="/Images/Program_icon.png">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E10600"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#E10600"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#333" BorderThickness="0,0,0,1">
                <Grid Margin="60,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Name="Team_Logo_Small" Width="50" Height="50" Margin="0,0,25,0"/>
                        <TextBlock Name="Team_Name_Top" Text="SCUDERIA FERRARI" Foreground="White" FontSize="32" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#151515" CornerRadius="5" Padding="20,8" BorderBrush="#E10600" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="BUDGET:" Foreground="#888" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <TextBlock Name="Budget_Label" Text="$ 15,800,000" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="60,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="DRIVER LINEUP" Foreground="#E10600" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>

                    <UniformGrid Rows="2" Height="800">
                        <Border Background="#0F0F0F" BorderBrush="#222" BorderThickness="1" Margin="0,0,0,10">
                            <Grid>
                                <Border Background="#E10600" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="12,5" Panel.ZIndex="10">
                                    <TextBlock Name="RatingLabel1" Text="92" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                </Border>
                                <Viewbox Stretch="Uniform" Margin="20,40,20,70">
                                    <Grid Width="300" Height="400">
                                        <Image Name="Driver1_Suit" VerticalAlignment="Bottom" Stretch="Uniform"/>
                                        <Image Name="Driver1_Face" Width="220" VerticalAlignment="Top" Margin="10,35,0,0" Stretch="Uniform"/>
                                    </Grid>
                                </Viewbox>
                                <Border VerticalAlignment="Bottom" Background="#151515" Padding="15">
                                    <StackPanel>
                                        <TextBlock Name="NameLabel1" Text="CHARLES LECLERC" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#0F0F0F" BorderBrush="#222" BorderThickness="1" Margin="0,10,0,0">
                            <Grid>
                                <Border Background="#E10600" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="12,5" Panel.ZIndex="10">
                                    <TextBlock Name="RatingLabel2" Text="88" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                </Border>
                                <Viewbox Stretch="Uniform" Margin="20,40,20,70">
                                    <Grid Width="300" Height="400">
                                        <Image Name="Driver2_Suit" VerticalAlignment="Bottom" Stretch="Uniform"/>
                                        <Image Name="Driver2_Face" Width="220" VerticalAlignment="Top" Margin="10,35,0,0" Stretch="Uniform"/>
                                    </Grid>
                                </Viewbox>
                                <Border VerticalAlignment="Bottom" Background="#151515" Padding="15">
                                    <StackPanel>
                                        <TextBlock Name="NameLabel2" Text="LEWIS HAMILTON" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="SCUDERIA FERRARI" Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <Grid Grid.Column="1" Margin="50,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Name="Car_Model_Name" Text="SF-26" Foreground="White" FontSize="80" FontWeight="Black" HorizontalAlignment="Center" Opacity="0.05"/>
                        <Image Name="Main_Car_Preview" Height="450" Stretch="Uniform" Margin="0,-80,0,0"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2">
                    <Border Background="#111" Padding="25" BorderBrush="#E10600" BorderThickness="2,0,0,0">
                        <StackPanel>
                            <TextBlock Text="CURRENT DAY" Foreground="#555" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Name="DayLabel" Text="1" Foreground="White" FontSize="42" FontWeight="Black"/>
                            <TextBlock Name="YearLabel" Text="2026 SEASON" Foreground="#E10600" FontSize="14" FontWeight="Bold" Margin="0,5,0,25"/>
                            <Button Name="BtnSimulate" Content="CONTINUE" Style="{StaticResource NavButtonStyle}" Height="60" Click="BtnSimulate_Click" MouseEnter="Button_MouseEnter" FontSize="18"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0A0A0A" BorderBrush="#222" BorderThickness="1" Height="360" Margin="0,40,0,0" Padding="20">
                        <Grid>
                            <TextBlock Text="DEVELOPMENT LOG" Foreground="#333" FontSize="10" FontWeight="Bold" VerticalAlignment="Top"/>
                            <TextBlock Name="Development_Log" Margin="0,25,0,0" Foreground="#888" FontSize="13" TextWrapping="Wrap" FontFamily="Consolas">
                                [INFO] Systems Operational<LineBreak/>[STATUS] Factory Idle<LineBreak/>[WEATHER] Sunny at Maranello
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#222" BorderThickness="0,1,0,0">
                <Grid Margin="60,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="500"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <Border CornerRadius="5" ClipToBounds="True" Background="#111">
                            <MediaElement Name="Music_Visualizer" Source="Videos/Sound_Wave.mp4" LoadedBehavior="Manual" Stretch="UniformToFill" IsMuted="True" MediaEnded="WaveRepeat_Click"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                            <TextBlock Name="Song_Name" Text="F1 THEME REMIX" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>

                        <Button Name="NextSong" Grid.Column="2" Content="⏭" Style="{StaticResource PlayerButtonStyle}" FontSize="24" Click="BtnNextSong_Click" MouseEnter="Button_MouseEnter" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button Name="VolumeUp_Button" Content="+" Style="{StaticResource PlayerButtonStyle}" FontSize="14" Height="20" Click="Button_Click_2" MouseEnter="Button_MouseEnter"/>
                            <Button Name="VolumeDown_Button" Content="-" Style="{StaticResource PlayerButtonStyle}" FontSize="14" Height="20" Click="Button_Click_3" MouseEnter="Button_MouseEnter"/>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Grid.Column="1" Columns="6" Margin="40,20,0,20">
                        <Button Content="UPGRADES" Click="Button_Click_Upgrade" MouseEnter="Button_MouseEnter" Style="{StaticResource NavButtonStyle}" Margin="5,0"/>
                        <Button Content="CALENDAR" Click="Button_Click_Calendar" MouseEnter="Button_MouseEnter" Style="{StaticResource NavButtonStyle}" Margin="5,0"/>
                        <Button Content="WDC" Style="{StaticResource NavButtonStyle}" Click="Button_Click_WDC" MouseEnter="Button_MouseEnter" Margin="5,0"/>
                        <Button Content="WCC" Style="{StaticResource NavButtonStyle}" Click="Button_Click_WCC" MouseEnter="Button_MouseEnter" Margin="5,0"/>
                        <Button Content="MAIN MENU" Click="Button_Click_MainMenu" MouseEnter="Button_MouseEnter" Style="{StaticResource NavButtonStyle}" Margin="5,0"/>
                        <Button Content="EXIT" Click="Button_Click_1" MouseEnter="Button_MouseEnter" Style="{StaticResource NavButtonStyle}" Foreground="#E10600" Margin="5,0"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</Window>