<Window x:Class="F1_Manager_2026.Menu.MainCareerMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Title="F1 Manager 2026" 
        Height="1080" Width="1920"
        Background="#050505">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E10600"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#E10600"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#333" BorderThickness="0,0,0,1">
                <Grid Margin="60,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Name="Team_Logo_Small" Width="50" Height="50" Margin="0,0,25,0"/>
                        <TextBlock Name="Team_Name_Top" Text="SCUDERIA FERRARI" Foreground="White" FontSize="32" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#151515" CornerRadius="5" Padding="20,8" BorderBrush="#E10600" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="BUDGET:" Foreground="#888" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <TextBlock Name="Budget_Label" Text="$ 15,800,000" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="60,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="DRIVER LINEUP" Foreground="#E10600" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Border Background="#0F0F0F" BorderBrush="#222" BorderThickness="1" Height="420" Margin="0,0,0,20">
                        <Grid Background="Transparent">
                            <TextBlock Name="RatingLabel1" Text="92" Foreground="#E10600" FontSize="28" 
                                       FontWeight="Bold" HorizontalAlignment="Right" 
                                       Margin="0,10,15,0" Panel.ZIndex="10"/>

                            <Viewbox Stretch="Uniform" Margin="10,40,10,80">
                                <Grid Width="300" Height="400">
                                    <Image Name="Driver1_Suit" VerticalAlignment="Bottom" Stretch="Uniform"/>
                                    <Image Name="Driver1_Face" Width="220" VerticalAlignment="Top" 
                                           Margin="10,35,0,0" Stretch="Uniform"/>
                                </Grid>
                            </Viewbox>

                            <StackPanel VerticalAlignment="Bottom" Margin="10">
                                <TextBlock Name="NameLabel1" Text="CHARLES LECLERC" Foreground="White" FontSize="18" 
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="#0F0F0F" BorderBrush="#222" BorderThickness="1" Height="420">
                        <Grid Background="Transparent">
                            <TextBlock Name="RatingLabel2" Text="88" Foreground="#E10600" FontSize="28" 
                                       FontWeight="Bold" HorizontalAlignment="Right" 
                                       Margin="0,10,15,0" Panel.ZIndex="10"/>

                            <Viewbox Stretch="Uniform" Margin="10,40,10,80">
                                <Grid Width="300" Height="400">
                                    <Image Name="Driver2_Suit" VerticalAlignment="Bottom" Stretch="Uniform"/>
                                    <Image Name="Driver2_Face" Width="220" VerticalAlignment="Top" 
                                           Margin="10,35,0,0" Stretch="Uniform"/>
                                </Grid>
                            </Viewbox>

                            <StackPanel VerticalAlignment="Bottom" Margin="10">
                                <TextBlock Name="NameLabel2" Text="LEWIS HAMILTON" Foreground="White" FontSize="18" 
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="SCUDERIA FERRARI" Foreground="#888" FontSize="11" 
                                           HorizontalAlignment="Center" Margin="0,2,0,5"/>
                                <Border Background="#222" CornerRadius="5" Padding="8,5" BorderBrush="#444" BorderThickness="1">
                                    <Grid>
                                        <TextBlock Text="VALUE" Foreground="#666" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                        <TextBlock Name="ValueLabel2" Text="$ 32,000,000" Foreground="#00FF41" FontSize="15" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" Margin="50,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Name="Car_Model_Name" Text="SF-26" Foreground="White" FontSize="60" FontWeight="Black" HorizontalAlignment="Center" Opacity="0.1"/>
                        <Image Name="Main_Car_Preview" Height="446" Stretch="Uniform" Margin="0,-60,0,0"/>
                        <UniformGrid Columns="3" Margin="0,40,0,0"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2">
                    <Border Background="#111" Padding="25" BorderBrush="#E10600" BorderThickness="2,0,0,0">
                        <StackPanel>
                            <TextBlock Text="NEXT GP" Foreground="#555" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Name="NextRaceLabel" Text="BAHRAIN GP" Foreground="White" FontSize="32" FontWeight="Black"/>
                            <TextBlock Name="DateLabel" Text="MARCH 26 - 28" Foreground="#E10600" FontSize="14" FontWeight="Bold" Margin="0,5,0,20"/>
                            <Button Name="BtnSimulate" Content="CONTINUE SESSION" Style="{StaticResource NavButtonStyle}" Height="50"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0A0A0A" BorderBrush="#222" BorderThickness="1" Height="380" Margin="0,40,0,0">
                        <TextBlock Padding="20" Foreground="#888" FontSize="13" TextWrapping="Wrap">
                            [INFO] System Ready.<LineBreak/>[FINANCE] Budget stable.<LineBreak/>[ENGINE] All systems operational.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Background="#0A0A0A">
                <UniformGrid Columns="7" Margin="60,10">
                    <Button Content="UPGRADES" Click="Button_Click_Upgrade" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="FACILITIES" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="STAFF" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="CALENDAR" Click="Button_Click_Calendar" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="STANDINGS" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="SAVE" Click="Button_Click_Save" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="EXIT" Click="Button_Click_1" Style="{StaticResource NavButtonStyle}" Foreground="#E10600"/>
                </UniformGrid>
            </Grid>
        </Grid>
    </Viewbox>
</Window>