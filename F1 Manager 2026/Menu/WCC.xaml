<Window x:Class="F1_Manager_2026.WCC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Constructors' Standings" Height="1080" Width="1920"
        Background="#050505">

    <Window.Resources>
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#E10600"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="25,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TeamCardTemplate">
            <Border Background="#0F0F0F" BorderBrush="#222" BorderThickness="1" Margin="8" Height="240" Width="340">
                <Grid>
                    <Image Source="{Binding Logo}" Opacity="0.08" Margin="30" Stretch="Uniform"/>

                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,15,0">
                        <TextBlock Text="{Binding Rating}" Foreground="#E10600" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <Rectangle Width="15" Height="2" Fill="#E10600" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Image Source="{Binding Logo}" Width="200" Height="90" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,0,30"/>

                    <Border VerticalAlignment="Bottom" Background="#F20A0A0A" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="5,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="Black" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Points, StringFormat={}{0} PTS}" Foreground="#E10600" FontSize="16" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid Margin="60,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="5" Height="30" Fill="#E10600" Margin="0,0,15,0"/>
                    <TextBlock Text="CONSTRUCTORS' STANDINGS" Foreground="White" FontSize="24" FontWeight="Black">
                        <TextBlock.LayoutTransform>
                            <ScaleTransform ScaleX="1.05" />
                        </TextBlock.LayoutTransform>
                    </TextBlock>
                    <TextBlock Text=" | SEASON 2026" Foreground="#666" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <Button Content="BACK TO HQ" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource BackButtonStyle}" Click="BtnBack_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="60,40" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <StackPanel Margin="15,0">
                    <TextBlock Text="2" Foreground="#AAA" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ContentControl Content="{Binding Top2}" ContentTemplate="{StaticResource TeamCardTemplate}"/>
                </StackPanel>

                <StackPanel Margin="25,0">
                    <TextBlock Text="1" Foreground="#FFD700" FontSize="32" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Border BorderBrush="#E10600" BorderThickness="0,0,0,4">
                        <ContentControl Content="{Binding Top1}" ContentTemplate="{StaticResource TeamCardTemplate}">
                            <ContentControl.LayoutTransform>
                                <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                            </ContentControl.LayoutTransform>
                        </ContentControl>
                    </Border>
                </StackPanel>

                <StackPanel Margin="15,0">
                    <TextBlock Text="3" Foreground="#CD7F32" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ContentControl Content="{Binding Top3}" ContentTemplate="{StaticResource TeamCardTemplate}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2" Margin="60,10" VerticalScrollBarVisibility="Hidden">
            <ItemsControl ItemsSource="{Binding OtherTeams}" ItemTemplate="{StaticResource TeamCardTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#050505"/>
    </Grid>
</Window>