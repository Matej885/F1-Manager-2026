<Window x:Class="F1_Manager_2026.Calendar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:F1_Manager_2026"
        Title="RACE CALENDAR 2026" 
        WindowState="Maximized" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#050505">

    <Window.DataContext>
        <Binding Source="{x:Static local:Database.Instance}"/>
    </Window.DataContext>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF0000" Height="60" Margin="0,0,0,30">
            <TextBlock Text="S E A S O N   C A L E N D A R   -   2 0 2 6" 
                       Foreground="White" FontWeight="Black" 
                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                       FontSize="24" />
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Hidden" Margin="0,0,20,0">
                <ItemsControl ItemsSource="{Binding Calendar2026}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="8" Height="100" Background="#111111" BorderBrush="#333333" BorderThickness="2" Cursor="Hand" Click="Track_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0">
                                    <TextBlock Text="{Binding Round, StringFormat={}{0:00}}" Foreground="#FF0000" FontSize="32" FontWeight="Black" Margin="0,0,20,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CountryCode}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#666666" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#FF0000" BorderThickness="2,0,0,0" Padding="50,40"
                    DataContext="{Binding SelectedTrack}">
                <StackPanel>
                    <TextBlock Text="SELECTED CIRCUIT" Foreground="#FF0000" FontWeight="Bold" FontSize="13" Margin="0,0,0,20"/>

                    <Border Height="280" Background="White" CornerRadius="5" BorderBrush="#222222" BorderThickness="1" Margin="0,0,0,30">
                        <Grid>
                            <TextBlock Text="" Foreground="#DDD" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            <Image Source="{Binding ImagePath}" 
                                   Stretch="Uniform" 
                                   Margin="15"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="34" FontWeight="Black" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding CircuitName}" Foreground="#FF0000" FontSize="16" FontWeight="Bold" Margin="0,8,0,40"/>

                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,15">
                            <TextBlock Text="LAPS" Foreground="#444" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Laps}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="0,15">
                            <TextBlock Text="DISTANCE" Foreground="#444" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{Binding RaceDistance}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="0,15">
                            <TextBlock Text="TRACK LENGTH" Foreground="#444" FontSize="12" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Length}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text=" KM" Foreground="White" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </UniformGrid>

                    <Separator Background="#222" Margin="0,40"/>

                    <TextBlock Text="TYRE ALLOCATION" Foreground="#444" FontSize="12" FontWeight="Bold" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="24" Height="24" Fill="#FF0000" Margin="0,0,10,0"/>
                        <Ellipse Width="24" Height="24" Fill="#F1C40F" Margin="0,0,10,0"/>
                        <Ellipse Width="24" Height="24" Fill="#FFFFFF" Margin="0,0,10,0"/>
                        <TextBlock Text="C5 - C4 - C3" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>