<Window x:Class="F1_Manager_2026.Menu.Upgrades"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Team R&amp;D Center" Height="1080" Width="1920">

    <Window.Resources>
        <Style x:Key="UpgradeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="Background" Value="#222"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="F1ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E10600"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1E14"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#050505">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="3" VerticalAlignment="Top" Height="100" Background="#0A0A0A" BorderBrush="Red" BorderThickness="0,0,0,4">
            <Grid Margin="60,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="8" Height="40" Fill="Red" Margin="0,0,15,0"/>
                    <TextBlock Text="R&amp;D PERFORMANCE CENTER" Foreground="White" FontSize="36" FontWeight="Black" FontStyle="Italic" FontFamily="Bahnschrift"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="SEASON 2026" Foreground="#666" FontSize="18" VerticalAlignment="Center" Margin="0,0,30,0" FontWeight="Bold"/>
                    <Border Background="#1A1A1A" Padding="20,10" CornerRadius="5" BorderBrush="LightGreen" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="FUNDS:" Foreground="#AAA" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Name="Budget" Text="0 $$$" Foreground="LightGreen" FontSize="22" FontWeight="Bold" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Column="0" Margin="40,140,20,0">
            <TextBlock Text="FACILITY STATUS" Foreground="Red" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <Border Background="#111" BorderBrush="#333" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Name="WindTunnel_Text" Text="WIND TUNNEL: OPERATIONAL" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                    <TextBlock Name="CFD_Text" Text="CFD SUPERCOMPUTER: IDLE" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                    <TextBlock Name="Dyno_Text" Text="ENGINE DYNO: ACTIVE" Foreground="White" FontSize="14"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20,140,20,0">
            <TextBlock Text="AERODYNAMIC &amp; MECHANICAL DEVELOPMENT" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <UniformGrid Columns="3" Height="380">
                <Border Style="{StaticResource UpgradeCardStyle}">
                    <Grid>
                        <StackPanel VerticalAlignment="Top">
                            <Border Background="#222" Height="100" Margin="0,0,0,15">
                                <Image Name="Engine_Image" Stretch="Uniform" Margin="10"/>
                            </Border>
                            <TextBlock Text="POWER UNIT" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Name="Engine_UpgradeLevel" Text="LEVEL 0 / 5" Foreground="Red" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button Name="PowerUnit_Upgrade" Content="INITIATE UPGRADE" Style="{StaticResource F1ButtonStyle}" Height="45" VerticalAlignment="Bottom" Click="PowerUnit_Upgrade_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource UpgradeCardStyle}">
                    <Grid>
                        <StackPanel VerticalAlignment="Top">
                            <Border Background="#222" Height="100" Margin="0,0,0,15">
                                <Image Source="/Images/aerodynamics.png" Stretch="Uniform" Margin="10"/>
                            </Border>
                            <TextBlock Text="AERODYNAMICS" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Name="AeroUpgradeLevel" Text="LEVEL 0 / 5" Foreground="Red" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button Name="Aero_Upgrade" Content="INITIATE UPGRADE" Style="{StaticResource F1ButtonStyle}" Height="45" VerticalAlignment="Bottom" Click="Aero_Upgrade_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource UpgradeCardStyle}">
                    <Grid>
                        <StackPanel VerticalAlignment="Top">
                            <Border Background="#222" Height="100" Margin="0,0,0,15">
                                <Image Source="/Images/chassis.jpg" Stretch="Uniform" Margin="10"/>
                            </Border>
                            <TextBlock Text="CHASSIS" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Name="Chassis_UpgradeLevel" Text="LEVEL 0 / 5" Foreground="Red" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button Name="Chassis_Upgrade" Content="INITIATE UPGRADE" Style="{StaticResource F1ButtonStyle}" Height="45" VerticalAlignment="Bottom" Click="Chassis_Upgrade_Click"/>
                    </Grid>
                </Border>
            </UniformGrid>

            <ProgressBar x:Name="AeroVisualBar" Visibility="Collapsed"/>
            <ProgressBar x:Name="ChassisVisualBar" Visibility="Collapsed"/>
            <ProgressBar x:Name="EngineVisualBar" Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="20,140,40,0">
            <TextBlock Text="DEVELOPMENT LOG" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
            <Border Background="#0A0A0A" BorderBrush="Red" BorderThickness="1,0,0,0" Height="400">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Name="Upgrades_Log" Foreground="#888" FontSize="13" TextWrapping="Wrap" FontFamily="Consolas" Padding="15" LineHeight="20"/>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <Button Content="RETURN TO HQ" Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                Margin="0,0,40,40" Width="300" Height="70" Background="Transparent" Foreground="White" 
                BorderBrush="White" BorderThickness="2" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="Button_Click_Back" />

        <Button Content="EXIT" Grid.Column="2" Background="#440000" Foreground="Gray" FontSize="10" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10" 
                Width="60" Height="20" Click="Button_Click_Close" BorderThickness="0"/>
    </Grid>
</Window>