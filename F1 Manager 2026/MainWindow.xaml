<Window x:Class="F1_Manager_2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:F1_Manager_2026"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Icon= "/Images/F1 Manager 2026 logo.png"
        Title="F1 Manager 2026" Height="1080" Width="1920"
        MouseDown="Window_MouseDown">
    <Grid Background="Black">
        <MediaElement Name="Loading_Screen_Intro_Media_Element" 
                  LoadedBehavior="Manual" 
                  UnloadedBehavior="Manual" 
                  Source="Videos/Loading_Screen_Source.mp4" 
                  MediaEnded="MediaRepeat"
                  Stretch="UniformToFill" />

    </Grid>
</Window>
