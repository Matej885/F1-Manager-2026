<Window x:Class="F1_Manager_2026.Options"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:F1_Manager_2026"
        mc:Ignorable="d"
        Title="Options" 
        Height="1080" Width="1920"
        WindowStyle="None"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <MediaElement Name="options_Media_Element" 
                      LoadedBehavior="Manual" 
                      UnloadedBehavior="Manual" 
                      Stretch="UniformToFill" 
                      MediaEnded="MediaRepeat" 
                      IsMuted="True" 
                      Source="Videos/Options Video.mp4" />

        <Label Content="Manager 2026" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Top" 
               Margin="211,72,0,0" 
               FontWeight="Bold" 
               FontSize="24" 
               FontFamily="Bahnschrift" 
               Foreground="Red" 
               Background="{x:Null}" 
               Height="87" Width="472"/>

        <StackPanel VerticalAlignment="Bottom" 
                    HorizontalAlignment="Left" 
                    Margin="50,0,0,50" 
                    Width="430">

            <Button Name="Continue_Button" 
                    Content="Continue" 
                    Height="60" 
                    FontSize="22" 
                    FontWeight="Bold" 
                    Margin="0,0,0,15"
                    Click="Continue_Button_Click"
                    Background="#80000000" 
                    Foreground="White" 
                    Cursor="Hand"/>

            <Button Name="Career_Create_Button" 
                    Content="New Career" 
                    Height="260" 
                    FontSize="22" 
                    FontWeight="Bold" 
                    Click="Career_Create_Button_Click"
                    Foreground="White" 
                    
                    Cursor="Hand" 
                    Background="#80000000"/>

            <Button Name="Volume_Button" 
                    Width="77" Height="60" 
                    HorizontalAlignment="Left"
                    Margin="0,15,0,0" 
                    Click="Button_Click_4" 
                    Cursor="Hand" 
                    Background="#80000000">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <Button Content="Button" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" 
                Margin="0,0,50,50" 
                Height="119" Width="280" 
                Click="Button_Click"
                Background="#80000000"
                Foreground="White"/>

    </Grid>
</Window>