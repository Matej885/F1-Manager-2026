<Window x:Class="F1_Manager_2026.Test"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:F1_Manager_2026"
        mc:Ignorable="d"
        Title="Driver Selection Test" Height="500" Width="900" Background="#121212">

    <Grid>
        <Viewbox HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,20,0,0" Width="350" Height="450">
            <Grid Width="300" Height="400">
                <Image x:Name="racesuit_shower" 
                       VerticalAlignment="Bottom" 
                       Stretch="Uniform"
                       Source="Assets/Suits/suit_redbull.png"/>

                <Image x:Name="driverphoto_shower" 
                       Width="200" 
                       VerticalAlignment="Top" 
                       Margin="0,43,0,0" 
                       Stretch="Uniform"
                       Source="Assets/Heads/verstappen_head.png"/>
            </Grid>
        </Viewbox>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,50,0" Width="250">
            <Border Background="#1E1E1E" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Nastavenia jazdca" 
                               Foreground="White" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Margin="0,0,0,20" 
                               HorizontalAlignment="Center"/>

                    <Button Content="Načítať jazdca (Hulk)" 
                            Height="45" 
                            Click="ButtonHulk_Click"
                            Background="#E10600" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Načítať jazdca (Valtteri)" 
                            Height="45" Margin="0,10,0,0"
                            Click="ButtonValtteri_Click"
                            Background="#E10600" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Načítať jazdca (Bortoleto)" 
                            Height="45" Margin="0,10,0,0"
                            Click="ButtonBortoleto_Click"
                            Background="#E10600" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>

                    <TextBlock Foreground="#888" FontSize="11" Margin="0,20,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>