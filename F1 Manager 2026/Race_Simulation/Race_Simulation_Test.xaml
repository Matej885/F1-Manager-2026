<Window x:Class="F1_Manager_2026.Race_Simulation.Race_Simulation_Test"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Race Simulation" Height="500" Width="400" Background="#111"
        Icon="/Images/Program_icon.png">
    <StackPanel>
        <Button Content="SIMULATE (10x Average)" Click="StartSim_Click" Height="40" Margin="10" Background="Red" Foreground="White" FontWeight="Bold"/>
        <ListView x:Name="ResultsListView" Height="400" Margin="10" Background="#222" Foreground="White">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Pos" DisplayMemberBinding="{Binding Position}" Width="40"/>
                    <GridViewColumn Header="Driver" DisplayMemberBinding="{Binding Name}" Width="150"/>
                    <GridViewColumn Header="Avg Pos" DisplayMemberBinding="{Binding AvgPos}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>