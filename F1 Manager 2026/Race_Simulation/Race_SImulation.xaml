<Window x:Class="F1_Manager_2026.Race_Simulation.Race_Simulation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Race Simulation" WindowState="Maximized" WindowStyle="None" Background="#050505">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#0A0A0A" BorderBrush="Red" BorderThickness="0,0,0,4">
            <TextBlock x:Name="TrackNameLabel" Text="WAITING FOR START..." Foreground="White" FontSize="36" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <ListView x:Name="ResultsListView" Grid.Row="1" Grid.Column="0" Margin="20" Background="#111" Foreground="White" SelectionChanged="ResultsListView_SelectionChanged" Visibility="Collapsed">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="POS" DisplayMemberBinding="{Binding Position}" Width="50"/>
                    <GridViewColumn Header="DRIVER" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="PTS" DisplayMemberBinding="{Binding PointsEarned}" Width="50"/>
                    <GridViewColumn Header="AVG" DisplayMemberBinding="{Binding AvgPos}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid x:Name="StartSequenceOverlay" Grid.Row="1" Grid.ColumnSpan="2" Background="#050505">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,50">
                    <Ellipse x:Name="Light1" Width="60" Height="60" Fill="#222" Margin="10" Stroke="White" StrokeThickness="2"/>
                    <Ellipse x:Name="Light2" Width="60" Height="60" Fill="#222" Margin="10" Stroke="White" StrokeThickness="2"/>
                    <Ellipse x:Name="Light3" Width="60" Height="60" Fill="#222" Margin="10" Stroke="White" StrokeThickness="2"/>
                    <Ellipse x:Name="Light4" Width="60" Height="60" Fill="#222" Margin="10" Stroke="White" StrokeThickness="2"/>
                    <Ellipse x:Name="Light5" Width="60" Height="60" Fill="#222" Margin="10" Stroke="White" StrokeThickness="2"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" Text="PREPARING RACE..." Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <ProgressBar x:Name="SimProgressBar" Width="400" Height="10" Margin="0,20,0,0" Background="#111" Foreground="Red" BorderThickness="0"/>

                <Button x:Name="BtnStartSim" Content="LIGHTS OUT" Click="BtnStartSim_Click" Margin="0,40,0,0" Width="200" Height="60" Background="Red" Foreground="White" FontWeight="Bold" FontSize="20"/>
            </StackPanel>
        </Grid>

        <Border x:Name="DriverDetailPanel" Grid.Row="1" Grid.Column="1" Background="#0A0A0A" Visibility="Collapsed" BorderBrush="#333" BorderThickness="2,0,0,0">
            <StackPanel Margin="20">
                <Image x:Name="DetailPhoto" Height="250" Stretch="Uniform"/>
                <TextBlock x:Name="DetailName" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                <TextBlock x:Name="DetailTeam" Foreground="#888" FontSize="16" HorizontalAlignment="Center"/>
                <Button Content="CLOSE" Click="CloseDetail_Click" Margin="0,20,0,0" Height="40" Background="Red" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Button x:Name="FinishBtn" Content="FINISH" Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="40" Width="150" Height="50" Click="FinishButton_Click" Background="Gray" Visibility="Collapsed"/>
    </Grid>
</Window>