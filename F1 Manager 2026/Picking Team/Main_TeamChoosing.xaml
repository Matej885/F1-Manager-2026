<Window x:Class="F1_Manager_2026.Picking_Team.Main_TeamChoosing"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:F1_Manager_2026.Picking_Team"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Main_TeamChoosing" Height="1080" Width="1920">

    <Grid Background="#0F0F0F">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="3" VerticalAlignment="Top" Height="80" Background="#1A1A1A" BorderBrush="Red" BorderThickness="0,0,0,3">
            <Label Content="F1 TEAM SELECTION 2026" Foreground="White" FontSize="32" FontFamily="Bahnschrift" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <StackPanel Grid.Column="0" Margin="40,120,20,0">
            <Label Content="TEAM PRINCIPAL PROFILE" Foreground="Red" FontSize="20" FontFamily="Bahnschrift" FontWeight="Bold" Margin="0,0,0,20"/>

            <Label Content="First Name:" Foreground="Gray" FontFamily="Bahnschrift"/>
            <TextBox Name = "Name_Label"  Text="Matej" Height="35" FontSize="18" Margin="0,5,0,15" Background="#252525" Foreground="White" BorderBrush="#444" VerticalContentAlignment="Center" Padding="5,0"/>

            <Label Content="Last Name:" Foreground="Gray" FontFamily="Bahnschrift"/>
            <TextBox Name = "Surname_Label" Text="Tichý" Height="35" FontSize="18" Margin="0,5,0,30" Background="#252525" Foreground="White" BorderBrush="#444" VerticalContentAlignment="Center" Padding="5,0"/>

            <Border BorderBrush="#333" BorderThickness="1" Padding="10" CornerRadius="5" Margin="0,50,0,0">
                <StackPanel>
                    <Label Content="CURRENT VEHICLE PREVIEW" Foreground="White" HorizontalAlignment="Center" FontFamily="Bahnschrift" FontWeight="Bold"/>
                    <Image Name="Car_Shower" Height="250" Margin="0,10" Stretch="Uniform"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20,120,20,0" HorizontalAlignment="Center">
            <Label Content="SELECT YOUR ORIGIN / TEAM" Foreground="White" FontSize="18" HorizontalAlignment="Center" FontFamily="Bahnschrift" Margin="0,0,0,20"/>

            <UniformGrid Columns="4" Width="400" Height="80">
                <Button Name = "Main_Button" Content="1" Margin="5,0,5,5" Background="#222" Foreground="White" FontSize="28" BorderBrush="White" Click="Button_Click" MouseEnter="Main_Button_MouseEnter" Cursor="Hand" Height="70" VerticalAlignment="Bottom"/>
                <Button Content="2" Margin="5,0,5,5" Background="#222" Foreground="White" FontSize="28" BorderBrush="White" Click="Button_Click_1" MouseEnter="Main_Button_MouseEnter" Cursor="Hand" Height="70" VerticalAlignment="Bottom"/>
                <Button Content="3" Margin="5" Background="#222" Foreground="White" FontSize="28" BorderBrush="White" MouseEnter="Main_Button_MouseEnter" Click="Button_Click_2" Cursor="Hand"/>
                <Button Content="4" Margin="5" Background="#222" Foreground="White" FontSize="28" BorderBrush="White" MouseEnter="Main_Button_MouseEnter" Click="Button_Click_3" Cursor="Hand"/>
            </UniformGrid>

            <Label Name="Team_Name_Label" Content="TEAM NAME" Margin="0,40,0,0" HorizontalAlignment="Center" Foreground="White" FontSize="36" FontWeight="Bold" FontFamily="Bahnschrift"/>
            <Image Name="Logo_Shower" Height="150" Width="150" Margin="0,20" Stretch="Uniform"/>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,40,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Name="Car_Speed_Label" Content="CAR PERFORMANCE:" Foreground="White" FontSize="16" FontFamily="Bahnschrift" Visibility="Visible"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Rectangle Name="Car_Speed_Rectangle1" Width="12" Height="25" Margin="2" Fill="Red" Stroke="White"/>
                        <Rectangle Name="Car_Speed_Rectangle2" Width="12" Height="25" Margin="2" Fill="Red" Stroke="White"/>
                        <Rectangle Name="Car_Speed_Rectangle3" Width="12" Height="25" Margin="2" Fill="#333" Stroke="White"/>
                        <Rectangle Name="Car_Speed_Rectangle4" Width="12" Height="25" Margin="2" Fill="#333" Stroke="White"/>
                        <Rectangle Name="Car_Speed_Rectangle5" Width="12" Height="25" Margin="2" Fill="#333" Stroke="White"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Label Name="Money_Label" Content="BUDGET:" Foreground="White" FontSize="16" FontFamily="Bahnschrift"/>
                    <Label Name="Money_Description_Label" Content="$$$" Foreground="LightGreen" FontSize="16" FontWeight="Bold" FontFamily="Bahnschrift"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="20,120,40,0">
            <Label Content="TEAM BIOGRAPHY" Foreground="Red" FontSize="20" FontFamily="Bahnschrift" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Name="Description_Text" TextWrapping="Wrap" Foreground="White" FontSize="16" FontFamily="Bahnschrift" TextAlignment="Justify" Height="400">
                To see stats abou teams first select one of them. Each team has different budget, car performance and difficulty. You can also see team biography and current car preview. Choose wisely, because you will be with this team for whole career.
            </TextBlock>

            <Label Name="Difficulty_Label" Content="DIFFICULTY" Foreground="White" Margin="0,20,0,5" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal">
                <Image Name="Difficulty_Grid1" Width="40" Height="25" Margin="2"/>
                <Image Name="Difficulty_Grid2" Width="40" Height="25" Margin="2"/>
                <Image Name="Difficulty_Grid3" Width="40" Height="25" Margin="2"/>
                <Image Name="Difficulty_Grid4" Width="40" Height="25" Margin="2"/>
            </StackPanel>
        </StackPanel>

        <Button Content="CONFIRM SELECTION" Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                Margin="0,0,40,40" Width="250" Height="60" Background="Red" Foreground="White" 
                MouseEnter="Main_Button_MouseEnter"
                FontSize="20" FontWeight="Bold" FontFamily="Bahnschrift" Click="Button_Click_4" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>