<Window x:Class="F1_Manager_2026.Picking_Team.Avatar_Pick"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowState="Maximized" 
        WindowStyle="None" 
        Title="Avatar Selection" 
        Height="1080" 
        Width="1920">

    <Grid Background="#0F0F0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="Red" BorderThickness="0,0,0,3">
            <Grid Margin="40,0">
                <Label Content="CHARACTER CUSTOMIZATION" Foreground="White" FontSize="32" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Bahnschrift"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="MANAGER:" Foreground="#888" FontSize="14" 
                               VerticalAlignment="Center" Margin="0,5,15,0" FontWeight="Bold" FontFamily="Bahnschrift"/>
                    <Border Background="#222" CornerRadius="5" Padding="15,5" BorderBrush="Red" BorderThickness="1" Width="422">
                        <TextBlock x:Name="PlayerNameDisplay" Text="---" Foreground="White" 
                                   FontSize="24" FontWeight="Bold" FontFamily="Bahnschrift"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#151515" Margin="20" CornerRadius="15" BorderBrush="#333" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="10">
                    <ItemsControl x:Name="AvatarsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="AvatarCard" Background="#1A1A1A" Margin="5" CornerRadius="10" 
                                        Cursor="Hand" MouseDown="AvatarCard_MouseDown"
                                        MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave"
                                        BorderBrush="#333" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Margin="10">
                                        <Image Source="{Binding PhotoPath}" Width="70" Height="70" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" 
                                                   Margin="20,0,0,0" FontSize="18" FontWeight="SemiBold" FontFamily="Bahnschrift"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Margin="20">
                <Border Background="#151515" CornerRadius="20" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <Viewbox Stretch="Uniform" Margin="50">
                            <Grid Width="300" Height="400">
                                <Image x:Name="PreviewHead" 
                                       Width="220" 
                                       VerticalAlignment="Top" 
                                       Margin="4,33,0,0" 
                                       Stretch="Uniform"
                                       Panel.ZIndex="1"/>

                                <Image x:Name="PreviewSuit" 
                                       VerticalAlignment="Bottom" 
                                       Stretch="Uniform"
                                       Panel.ZIndex="2"/>
                            </Grid>
                        </Viewbox>

                        <Button Content="CONFIRM SELECTION" MouseEnter="Card_MouseEnter" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                                Margin="40" Padding="30,15" Background="Red" Foreground="White" FontSize="20"
                                FontWeight="Bold" Click="Confirm_Click" Cursor="Hand" FontFamily="Bahnschrift">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background" Value="#B00500"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
            <Button  Background="DarkRed" MouseEnter="Card_MouseEnter"  FontSize="10" Content="Close game" HorizontalAlignment="Right" VerticalAlignment="Bottom" Height="23" Width="76" Click="Button_Click" Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>