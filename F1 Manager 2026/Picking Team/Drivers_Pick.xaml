<Window x:Class="F1_Manager_2026.Picking_Team.Drivers_Pick"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowState="Maximized" WindowStyle="None" Title="Drivers_Pick" Height="1080" Width="1920">

    <Grid Background="#0F0F0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style x:Key="DriverCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A"/>
                <Setter Property="BorderBrush" Value="#333333"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Margin" Value="15"/>
                <Setter Property="Width" Value="250"/>
                <Setter Property="Height" Value="380"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="Red"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="Red" BorderThickness="0,0,0,3">
            <Label Content="F1 DRIVER SELECTION 2026" Foreground="White" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <ItemsControl x:Name="DriversItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource DriverCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Skill}" Foreground="Red" FontSize="32" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,5,10,0" Panel.ZIndex="10"/>
                                <Grid Grid.Row="1">
                                    <Image Source="{Binding SuitPath}" VerticalAlignment="Bottom" Stretch="Uniform" Height="220"/>
                                    <Image Source="{Binding PhotoPath}" Width="160" VerticalAlignment="Top" Stretch="Uniform" Margin="0,10,0,0"/>
                                </Grid>
                                <StackPanel Grid.Row="2" Background="#111" Margin="2">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding Team}" Foreground="#888" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding FormattedCost}" Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,10" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>