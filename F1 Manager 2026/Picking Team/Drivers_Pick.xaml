<Window x:Class="F1_Manager_2026.Picking_Team.Drivers_Pick"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowState="Maximized" 
        WindowStyle="None" 
        Title="Drivers_Pick" 
        Height="1080" 
        Width="1920">

    <Grid Background="#0F0F0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="Red" BorderThickness="0,0,0,3">
            <Grid Margin="40,0">
                <Label Content="F1 DRIVER SELECTION 2026" Foreground="White" FontSize="32" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="TEAM BUDGET:" Foreground="#888" FontSize="14" 
                               VerticalAlignment="Center" Margin="0,5,15,0" FontWeight="Bold"/>
                    <Border Background="#222" CornerRadius="5" Padding="15,5" BorderBrush="#00FF41" BorderThickness="1">
                        <TextBlock x:Name="BudgetDisplay" Text="0 $" Foreground="#00FF41" 
                                   FontSize="24" FontWeight="Bold" FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <ItemsControl x:Name="DriversItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="DriverCard" 
                                Background="#1A1A1A" 
                                BorderBrush="#333" 
                                BorderThickness="2" 
                                CornerRadius="12" 
                                Margin="10" 
                                Width="280" 
                                Height="420"
                                MouseEnter="DriverCard_MouseEnter"
                                MouseLeave="DriverCard_MouseLeave"
                                MouseDown="DriverCard_MouseDown">

                            <Grid Background="Transparent">
                                <TextBlock Text="{Binding Skill}" Foreground="Red" FontSize="28" 
                                           FontWeight="Bold" HorizontalAlignment="Right" 
                                           Margin="0,10,15,0" Panel.ZIndex="10"/>

                                <Viewbox Stretch="Uniform" Margin="10,40,10,80">
                                    <Grid Width="300" Height="400">
                                        <Image Source="{Binding SuitPath}" VerticalAlignment="Bottom" Stretch="Uniform"/>
                                        <Image Source="{Binding PhotoPath}" Width="220" VerticalAlignment="Top" 
                                               Margin="10,35,0,0" Stretch="Uniform"/>
                                    </Grid>
                                </Viewbox>

                                <StackPanel VerticalAlignment="Bottom" Margin="10">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="18" 
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Team}" Foreground="#888" FontSize="11" 
                                               HorizontalAlignment="Center" Margin="0,2,0,5"/>

                                    <Border Background="#222" CornerRadius="5" Padding="8,5" BorderBrush="#444" BorderThickness="1">
                                        <Grid>
                                            <TextBlock Text="VALUE" Foreground="#666" FontSize="9" 
                                                       FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding FormattedCost}" Foreground="#00FF41" 
                                                       FontSize="15" HorizontalAlignment="Right" FontWeight="Bold"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>