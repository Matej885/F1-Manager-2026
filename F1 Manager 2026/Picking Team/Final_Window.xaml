<Window x:Class="F1_Manager_2026.Picking_Team.Final_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="F1 Manager 2026 - Final Contract" 
        WindowState="Maximized" 
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Black"
        Icon="/Images/Program_icon.png">

    <Grid>
        <Grid x:Name="BackgroundStage">
            <Image Source="/Images/WorkTable.png" Stretch="UniformToFill">
                <Image.Effect>
                    <BlurEffect Radius="25"/>
                </Image.Effect>
            </Image>
            <Rectangle Opacity="0.9">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="1" RadiusY="1">
                        <GradientStop Color="#2A1A1A" Offset="0"/>
                        <GradientStop Color="#050505" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <Border Width="1100" Height="850" VerticalAlignment="Center" HorizontalAlignment="Center" 
                Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="5">
            <Grid Margin="45">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="ImgTeamLogo" Width="150" Height="80" Stretch="Uniform"/>

                    <StackPanel Grid.Column="1" Margin="30,0" VerticalAlignment="Center">
                        <TextBlock Text="OFFICIAL SEASON ENTRY - 2026" Foreground="#D4AF37" FontSize="12" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtBudget" Foreground="#00FF41" FontSize="22" FontWeight="Bold" Width="150"/>
                        <TextBlock x:Name="TxtTeamName" Text="TEAM NAME" Foreground="White" FontSize="34" FontWeight="ExtraBold"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="#111" Padding="20" Margin="0,0,0,20" CornerRadius="3" BorderBrush="#222" BorderThickness="1">
                    <TextBlock x:Name="TxtContractDescription" TextWrapping="Wrap" Foreground="#CCC" FontSize="14" LineHeight="20">
                        <Run Text="CONTRACT:" Foreground="#D4AF37" FontWeight="Bold"/>
                        <LineBreak/>
                        <Run Text="With this document, the Manager confirms the entry for the 2026 season. The contract becomes effective upon the date of signature. All personnel and technical requirements comply with the FIA Formula One World Championship regulations."/>
                    </TextBlock>
                </Border>

                <UniformGrid Grid.Row="2" Columns="2">
                    <Border Margin="10" Background="#222" BorderBrush="#333" BorderThickness="1" CornerRadius="5">
                        <Grid>
                            <TextBlock x:Name="TxtDriver1Rating" Foreground="Red" FontSize="28" FontWeight="Bold" HorizontalAlignment="Right" Margin="15,10"/>
                            <Viewbox Stretch="Uniform" Margin="10,20,10,70">
                                <Grid Width="300" Height="400">
                                    <Image x:Name="ImgDriver1Suit" VerticalAlignment="Bottom" Stretch="Uniform"/>
                                    <Image x:Name="ImgDriver1Face" Width="220" VerticalAlignment="Top" Margin="10,35,0,0" Stretch="Uniform"/>
                                </Grid>
                            </Viewbox>
                            <TextBlock x:Name="TxtDriver1Name" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="15"/>
                        </Grid>
                    </Border>
                    <Border Margin="10" Background="#222" BorderBrush="#333" BorderThickness="1" CornerRadius="5">
                        <Grid>
                            <TextBlock x:Name="TxtDriver2Rating" Foreground="Red" FontSize="28" FontWeight="Bold" HorizontalAlignment="Right" Margin="15,10"/>
                            <Viewbox Stretch="Uniform" Margin="10,20,10,70">
                                <Grid Width="300" Height="400">
                                    <Image x:Name="ImgDriver2Suit" VerticalAlignment="Bottom" Stretch="Uniform"/>
                                    <Image x:Name="ImgDriver2Face" Width="220" VerticalAlignment="Top" Margin="10,35,0,0" Stretch="Uniform"/>
                                </Grid>
                            </Viewbox>
                            <TextBlock x:Name="TxtDriver2Name" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="15"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="3" Margin="0,30,0,0">
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="MANAGER'S OFFICIAL SIGNATURE" Foreground="#D4AF37" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>

                        <Grid Width="450" Height="100" Background="#0AFFFFFF">
                            <InkCanvas x:Name="SignatureCanvas" Background="Transparent">
                                <InkCanvas.DefaultDrawingAttributes>
                                    <DrawingAttributes Color="White" FitToCurve="True" Width="2" Height="2" />
                                </InkCanvas.DefaultDrawingAttributes>
                            </InkCanvas>
                            <Rectangle Fill="#D4AF37" Height="1" VerticalAlignment="Bottom" Margin="10,0,10,15"/>
                        </Grid>

                        <WrapPanel Margin="0,5,0,0">
                            <Button Content="Clear Signature" Click="ClearSignature_Click" Background="Transparent" Foreground="#666" BorderBrush="Transparent" Cursor="Hand" FontSize="10"/>
                            <TextBlock Text=" | " Foreground="#333" Margin="5,0"/>
                            <TextBlock x:Name="TxtManagerName" Text="PLAYER NAME" Foreground="#444" FontSize="14" FontFamily="Brush Script MT" VerticalAlignment="Center"/>
                        </WrapPanel>
                    </StackPanel>

                    <Button Name="BtnContinue" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="Hand" Click="BtnContinue_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#8B0000" Padding="40,20" CornerRadius="3">
                                    <TextBlock Text="SIGN &amp; FINALIZE" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#A80000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>